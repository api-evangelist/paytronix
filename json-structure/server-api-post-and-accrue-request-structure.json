{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/paytronix/refs/heads/main/json-structure/server-api-post-and-accrue-request-structure.json",
  "name": "PostAndAccrueRequest",
  "description": "PostAndAccrueRequest schema from Paytronix Server API",
  "type": "object",
  "properties": {
    "merchantId": {
      "type": "int32",
      "example": 1000
    },
    "storeCode": {
      "type": "string",
      "example": "1"
    },
    "check": {
      "$ref": "#/components/schemas/Check"
    },
    "cardInfo": {
      "$ref": "#/components/schemas/CardInfo"
    },
    "autoActivateCard": {
      "type": "boolean"
    },
    "terminal": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "receiptSettings": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "merchantId",
    "storeCode",
    "check",
    "cardInfo"
  ]
}