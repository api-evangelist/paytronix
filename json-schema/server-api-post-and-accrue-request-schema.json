{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostAndAccrueRequest",
  "description": "PostAndAccrueRequest schema from Paytronix Server API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/paytronix/refs/heads/main/json-schema/server-api-post-and-accrue-request-schema.json",
  "type": "object",
  "properties": {
    "merchantId": {
      "type": "integer",
      "example": 1000
    },
    "storeCode": {
      "type": "string",
      "example": "1"
    },
    "check": {
      "$ref": "#/components/schemas/Check"
    },
    "cardInfo": {
      "$ref": "#/components/schemas/CardInfo"
    },
    "autoActivateCard": {
      "type": "boolean"
    },
    "terminal": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "receiptSettings": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "merchantId",
    "storeCode",
    "check",
    "cardInfo"
  ]
}